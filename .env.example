# Environment variables for development
# Copy this file to .env and fill in the values

DATABASE_URL="postgresql://user:password@localhost:5432/agendamento_salas"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="8h"
PORT=3333
NODE_ENV="development"

# Created automatically when database has zero users
FIRST_COORDINATOR_NAME="Coordenador Admin"
FIRST_COORDINATOR_EMAIL="coordenador@fatec.sp.gov.br"
FIRST_COORDINATOR_PASSWORD="admin123"

# Email (SMTP) — SendGrid (ou Mailtrap para testes: https://mailtrap.io)
# Para SendGrid: SMTP_USER=apikey, SMTP_PASS=<sua_api_key>
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS="sua_sendgrid_api_key"
SMTP_FROM='"Agendamento de Salas" <seu-email-verificado@dominio.com>'
