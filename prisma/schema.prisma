// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PROFESSOR
  COORDENADOR
}

enum UserStatus {
  PENDENTE
  APROVADO
}


model User {
  id         String     @id @default(uuid())
  name       String
  email      String     @unique
  password   String
  role       UserRole
  status     UserStatus @default(PENDENTE)
  approvedAt DateTime?  @map("approved_at")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")
  reservas   Reserva[]

  @@map("users")
}

enum ClassType {
  SALA
  LABORATORIO
  AUDITORIO
}

enum ClassStatus {
  INDISPONIVEL
  DISPONIVEL
}

model Class {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  capacity    Int
  type        ClassType
  status      ClassStatus  @default(DISPONIVEL)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  reservas    Reserva[]

  @@map("classes")
}

model Reserva {
  id            String    @id @default(uuid())
  professorId   String
  classId       String
  data          DateTime
  horario       String
  periodo       String
  semestre      String
  status        String
  justificativa String?
  createdAt     DateTime  @default(now())

  professor User  @relation(fields: [professorId], references: [id])
  class     Class @relation(fields: [classId], references: [id])
}
